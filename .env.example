# DreamSync 环境变量配置
# 复制此文件为 .env 并填写真实值

# ==================== 微信开放平台配置 ====================
# 申请地址：https://open.weixin.qq.com

# 微信开放平台 AppID（必填）
# 示例：wx1234567890abcdef
WECHAT_APPID=

# 微信开放平台 AppSecret（必填，32位字符串）
# 示例：1234567890abcdef1234567890abcdef
WECHAT_APPSECRET=

# 是否启用微信登录（true/false）
# 开发时可设为 false，使用模拟登录
WECHAT_ENABLED=false

# 授权回调域名（不带 https://）
# 示例：dreamsync.example.com
WECHAT_REDIRECT_DOMAIN=

# ==================== 服务器配置 ====================

# 服务端口
PORT=9999

# JWT 密钥（用于生成 token）
JWT_SECRET=dreamsync-secret-key-change-in-production

# ==================== 数据库配置（可选） ====================

# DATABASE_URL=postgresql://user:password@localhost:5432/dreamsync

# ==================== 其他配置 ====================

# 环境（development/production）
NODE_ENV=development
